@model List<İşlem>
@{
    ViewData["Title"] = "Log Kayıtları";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Log Kayıtları</h2>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Log Ekle</a>
</div>

@if (TempData["AnomalyAlert"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <strong>@TempData["AnomalyAlert"]</strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Zaman</th>
                    <th>Kullanıcı</th>
                    <th>İşlem</th>
                    <th>Kaynak</th>
                    <th>IP</th>
                    <th>Anomali</th>
                    <th>Skor</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr class="@(log.anormal ? "table-danger" : "")">
                        <td>@log.işlem_id</td>
                        <td>@log.tarih.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td>@log.kul_adı</td>
                        <td>@log.işlem</td>
                        <td>@log.kaynak</td>
                        <td>@log.ip</td>
                        <td>
                            @if (log.anormal)
                            {
                                <span class="badge bg-danger">ANOMALİ</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Normal</span>
                            }
                        </td>
                        <td>
                            @if (log.anormal)
                            {
                                <span class="badge @(log.puan >= 80 ? "bg-danger" : log.puan >= 60 ? "bg-warning" : "bg-info")">@log.puan</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">Henüz log kaydı bulunmuyor.</div>
}
