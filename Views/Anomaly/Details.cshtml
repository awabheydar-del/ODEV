@model İşlem
@{
    ViewData["Title"] = "Anomali Detayı";
    string severity = "Normal";
    if (Model.puan >= 80) severity = "Kritik";
    else if (Model.puan >= 60) severity = "Yüksek";
    else if (Model.puan >= 50) severity = "Orta";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header @(severity == "Kritik" ? "bg-danger" : severity == "Yüksek" ? "bg-warning" : "bg-info") text-white">
                <h4 class="mb-0">Anomali Detayı #@Model.işlem_id</h4>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4 fw-bold">Zaman:</div>
                    <div class="col-sm-8">@Model.tarih.ToString("dd.MM.yyyy HH:mm:ss")</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-bold">Kullanıcı:</div>
                    <div class="col-sm-8">@Model.kul_adı (@Model.kul_id)</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-bold">İşlem:</div>
                    <div class="col-sm-8"><span class="badge bg-secondary">@Model.işlem</span></div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-bold">Kaynak:</div>
                    <div class="col-sm-8"><code>@Model.kaynak</code></div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-bold">IP Adresi:</div>
                    <div class="col-sm-8"><code>@Model.ip</code></div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-bold">Başarı:</div>
                    <div class="col-sm-8">@(Model.başarılı ? "Evet" : "Hayır")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Anomali Analizi</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <h6>Anomali Skoru</h6>
                    <div class="display-3 fw-bold @(severity == "Kritik" ? "text-danger" : severity == "Yüksek" ? "text-warning" : "text-info")">
                        @Model.puan
                    </div>
                    <span class="badge @(severity == "Kritik" ? "bg-danger" : severity == "Yüksek" ? "bg-warning" : "bg-info") fs-6">
                        @(severity == "Kritik" ? "KRİTİK" : severity == "Yüksek" ? "YÜKSEK" : "ORTA")
                    </span>
                </div>
                <hr />
                <h6>Tespit Edilen Anomaliler:</h6>
                @if (!string.IsNullOrEmpty(Model.neden))
                {
                    var reasons = Model.neden.Split(" | ");
                    <ul class="list-group list-group-flush">
                        @foreach (var r in reasons)
                        {
                            <li class="list-group-item text-danger">
                                <small>@r</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary w-100">Geri Dön</a>
        </div>
    </div>
</div>
