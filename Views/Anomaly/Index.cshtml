@model List<LogEntry>
@{
    ViewData["Title"] = "Anomali Raporları";
}

<h2>Anomali Raporları</h2>
<hr />

@if (Model.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Zaman</th>
                        <th>Kullanıcı</th>
                        <th>İşlem</th>
                        <th>Kaynak</th>
                        <th>IP</th>
                        <th>Skor</th>
                        <th>Seviye</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr class="table-danger">
                            <td>@a.Id</td>
                            <td>@a.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                            <td>@a.UserName (@a.UserId)</td>
                            <td>@a.Action</td>
                            <td>@a.Resource</td>
                            <td>@a.IPAddress</td>
                            <td><span class="badge @(a.AnomalyScore >= 80 ? "bg-danger" : a.AnomalyScore >= 60 ? "bg-warning" : "bg-info")">@a.AnomalyScore</span></td>
                            <td>
                                <span class="badge @(a.Severity == "Critical" ? "bg-danger" : a.Severity == "High" ? "bg-warning" : "bg-info")">
                                    @(a.Severity == "Critical" ? "Kritik" : a.Severity == "High" ? "Yüksek" : "Orta")
                                </span>
                            </td>
                            <td><a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-danger">Detay</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-success">
        <h4 class="mb-0">Henüz anomali tespit edilmedi.</h4>
    </div>
}
