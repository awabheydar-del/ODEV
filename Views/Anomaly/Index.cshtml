@model List<İşlem>
@{
    ViewData["Title"] = "Anomali Raporları";
}

<h2>Anomali Raporları</h2>
<hr />

@if (Model.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Zaman</th>
                        <th>Kullanıcı</th>
                        <th>İşlem</th>
                        <th>Kaynak</th>
                        <th>IP</th>
                        <th>Skor</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr class="table-danger">
                            <td>@a.işlem_id</td>
                            <td>@a.tarih.ToString("dd.MM.yyyy HH:mm:ss")</td>
                            <td>@a.kul_adı (@a.kul_id)</td>
                            <td>@a.işlem</td>
                            <td>@a.kaynak</td>
                            <td>@a.ip</td>
                            <td><span class="badge @(a.puan >= 80 ? "bg-danger" : a.puan >= 60 ? "bg-warning" : "bg-info")">@a.puan</span></td>
                            <td><a asp-action="Details" asp-route-id="@a.işlem_id" class="btn btn-sm btn-outline-danger">Detay</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-success">
        <h4 class="mb-0">Henüz anomali tespit edilmedi.</h4>
    </div>
}
