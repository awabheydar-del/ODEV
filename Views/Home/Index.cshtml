@model DashboardViewModel
@{
    ViewData["Title"] = "Zero-Day Anomali Tespit Sistemi";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="alert alert-info d-flex align-items-center">
            <h4 class="mb-0 me-3">Zero-Day Davranış Anomali Tespit Sistemi</h4>
            <span class="badge bg-secondary fs-6">@DateTime.Now.ToString("dd.MM.yyyy HH:mm")</span>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-primary">
            <div class="card-body text-center">
                <h5 class="card-title text-primary">Toplam Log</h5>
                <h2 class="mb-0">@Model.TotalLogs</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-danger">
            <div class="card-body text-center">
                <h5 class="card-title text-danger">Tespit Edilen Anomali</h5>
                <h2 class="mb-0">@Model.TotalAnomalies</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-warning">
            <div class="card-body text-center">
                <h5 class="card-title text-warning">Anomali Oranı</h5>
                <h2 class="mb-0">%@Model.AnomalyRate</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-success">
            <div class="card-body text-center">
                <h5 class="card-title text-success">Son 24s Log</h5>
                <h2 class="mb-0">@Model.LogsLast24Hours</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h6>Kritik</h6>
                <h3>@Model.CriticalAnomalies</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-white">
            <div class="card-body text-center">
                <h6>Yüksek</h6>
                <h3>@Model.HighAnomalies</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h6>Orta</h6>
                <h3>@Model.MediumAnomalies</h3>
            </div>
        </div>
    </div>
</div>

@if (Model.RecentAnomalies.Any())
{
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Son Tespit Edilen Anomaliler</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Zaman</th>
                        <th>Kullanıcı</th>
                        <th>IP</th>
                        <th>İşlem</th>
                        <th>Skor</th>
                        <th>Sebep</th>
                        <th>Detay</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.RecentAnomalies)
                    {
                        <tr class="table-danger">
                            <td>@a.Timestamp.ToString("HH:mm:ss")</td>
                            <td>@a.UserName</td>
                            <td>@a.IPAddress</td>
                            <td>@a.Action</td>
                            <td><span class="badge @(a.AnomalyScore >= 80 ? "bg-danger" : a.AnomalyScore >= 60 ? "bg-warning" : "bg-info")">@a.AnomalyScore</span></td>
                            <td style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">@a.AnomalyReason</td>
                            <td><a asp-controller="Anomaly" asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-danger">Detay</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-success">
        <h5 class="mb-0">Henüz anomali tespit edilmedi. Sistem güvende.</h5>
    </div>
}
